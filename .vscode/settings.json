{
    "python.defaultInterpreterPath": "${workspaceFolder}/backend/venv/bin/python",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/backend"
    ],
    "files.associations": {
        "**/backend/**/*.html": "django-html"
    },
    "[django-html]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "JaaJYT.djlint"
    },
    "djlint.pythonPath": "${workspaceFolder}/backend/venv/bin/python",
    "djlint.executablePath": "${workspaceFolder}/backend/venv/bin/djlint"
}
